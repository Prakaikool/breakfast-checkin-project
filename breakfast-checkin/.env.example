
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/breakfast_checkin"
JWT_SECRET="CHANGE_ME_generate_a_random_secret_with_openssl_rand_base64_32"

# JWT token expiry (e.g., "8h" for 8 hours, "1d" for 1 day)
JWT_EXPIRY="8h"

# ---- Application ----
# The URL where the app runs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Breakfast service hours (24h format)
BREAKFAST_START_TIME="06:00"
BREAKFAST_END_TIME="11:00"

# Max guests allowed per room
MAX_GUESTS_PER_ROOM=6

# Dashboard polling interval in milliseconds (15000 = 15 seconds)
NEXT_PUBLIC_POLL_INTERVAL=15000
